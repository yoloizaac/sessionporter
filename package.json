{
  "name": "sessionporter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Export one AI coding session into a portable, reviewable, privacy-aware bundle. Local-first, no network, no runtime dependencies.",
  "bin": {
    "sessionporter": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:security": "vitest run tests/security",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:fixtures": "tsx scripts/validate-fixtures.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.2.4"
  }
}
